rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && request.auth.uid == data.userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(existing()) || (request.auth.uid == userId && incoming().keys().hasAll(['email', 'name']));
    }

    // Properties
    match /properties/{propertyId} {
      function isValidProperty(p) {
        return p.userId == request.auth.uid && p.name is string && p.name.size() > 0 && p.name.size() < 200;
      }
      allow read: if isSignedIn() && (isOwner(existing()) || exists(/databases/$(database)/documents/shares/$(propertyId + "_" + request.auth.uid)));
      allow create: if isSignedIn() && isValidProperty(incoming());
      allow update: if isSignedIn() && isOwner(existing()) && isValidProperty(incoming());
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Payments
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (isOwner(existing()) || exists(/databases/$(database)/documents/shares/$(existing().propertyId + "_" + request.auth.uid)));
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isOwner(existing()) && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Repairs
    match /repairs/{repairId} {
      allow read: if isSignedIn() && (isOwner(existing()) || exists(/databases/$(database)/documents/shares/$(existing().propertyId + "_" + request.auth.uid)));
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isOwner(existing()) && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Contractors
    match /contractors/{contractorId} {
      allow read: if isSignedIn() && isOwner(existing());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isOwner(existing()) && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (isOwner(existing()) || (existing().recipientEmail.lower() == request.auth.token.email.lower()));
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (isOwner(existing()) || (existing().recipientEmail.lower() == request.auth.token.email.lower()));
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Leases
    match /leases/{leaseId} {
      allow read: if isSignedIn() && (isOwner(existing()) || exists(/databases/$(database)/documents/shares/$(existing().propertyId + "_" + request.auth.uid)));
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isOwner(existing()) && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Lease Templates
    match /leaseTemplates/{templateId} {
      function isValidTemplate(t) {
        return t.userId == request.auth.uid && t.name is string && t.name.size() > 0 && t.content is string;
      }
      allow read: if isSignedIn() && isOwner(existing());
      allow create: if isSignedIn() && isValidTemplate(incoming());
      allow update: if isSignedIn() && isOwner(existing()) && isValidTemplate(incoming());
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Shares
    match /shares/{shareId} {
      allow read: if isSignedIn() && (existing().ownerId == request.auth.uid || existing().viewerId == request.auth.uid);
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && existing().ownerId == request.auth.uid && incoming().ownerId == request.auth.uid;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }
  }
}
