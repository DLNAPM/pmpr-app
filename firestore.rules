rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data != null && 'userId' in data && request.auth.uid == data.userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      function isValidUser(u) {
        return isValidString(u.email, 3, 200) && isValidString(u.name, 1, 100);
      }
      allow read: if isSignedIn();
      allow write: if (request.auth.uid == userId && (existing() == null ? isValidUser(incoming()) : true));
    }

    // Properties
    match /properties/{propertyId} {
      function isValidProperty(p) {
        return p.userId == request.auth.uid && 
               isValidString(p.name, 1, 200) && 
               isValidString(p.address, 1, 500) &&
               p.rentAmount is number && p.rentAmount >= 0;
      }
      allow read: if isSignedIn() && (isOwner(existing()) || exists(/databases/$(database)/documents/shares/$(propertyId + "_" + request.auth.uid)));
      allow create: if isSignedIn() && isValidProperty(incoming());
      allow update: if isSignedIn() && isOwner(existing()) && isValidProperty(incoming()) && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Payments
    match /payments/{paymentId} {
      function isValidPayment(p) {
        return p.userId == request.auth.uid && p.propertyId is string && p.year is number && p.month is number;
      }
      allow read: if isSignedIn() && (isOwner(existing()) || exists(/databases/$(database)/documents/shares/$(existing().propertyId + "_" + request.auth.uid)));
      allow create: if isSignedIn() && isValidPayment(incoming());
      allow update: if isSignedIn() && isOwner(existing()) && isValidPayment(incoming()) && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Repairs
    match /repairs/{repairId} {
      function isValidRepair(r) {
        return r.userId == request.auth.uid && r.propertyId is string && isValidString(r.description, 1, 2000);
      }
      allow read: if isSignedIn() && (isOwner(existing()) || exists(/databases/$(database)/documents/shares/$(existing().propertyId + "_" + request.auth.uid)));
      allow create: if isSignedIn() && isValidRepair(incoming());
      allow update: if isSignedIn() && isOwner(existing()) && isValidRepair(incoming()) && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Contractors
    match /contractors/{contractorId} {
      function isValidContractor(c) {
        return c.userId == request.auth.uid && isValidString(c.name, 1, 200);
      }
      allow read: if isSignedIn() && isOwner(existing());
      allow create: if isSignedIn() && isValidContractor(incoming());
      allow update: if isSignedIn() && isOwner(existing()) && isValidContractor(incoming()) && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (isOwner(existing()) || (existing().recipientEmail.toLower() == request.auth.token.email.toLower()));
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (isOwner(existing()) || (existing().recipientEmail.toLower() == request.auth.token.email.toLower()));
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Leases
    match /leases/{leaseId} {
      function isValidLease(l) {
        return l.userId == request.auth.uid && l.propertyId is string;
      }
      allow read: if isSignedIn() && (isOwner(existing()) || exists(/databases/$(database)/documents/shares/$(existing().propertyId + "_" + request.auth.uid)));
      allow create: if isSignedIn() && isValidLease(incoming());
      allow update: if isSignedIn() && isOwner(existing()) && isValidLease(incoming()) && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Lease Templates
    match /leaseTemplates/{templateId} {
      function isValidTemplate(t) {
        return t.userId == request.auth.uid && 
               t.name is string && t.name.size() > 0 && t.name.size() <= 200 &&
               t.content is string;
      }
      allow read: if isSignedIn() && isOwner(existing());
      allow create: if isSignedIn() && isValidTemplate(incoming());
      allow update: if isSignedIn() && isOwner(existing()) && isValidTemplate(incoming()) && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Shares
    match /shares/{shareId} {
      allow read: if isSignedIn() && (existing().ownerId == request.auth.uid || existing().viewerId == request.auth.uid);
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && existing().ownerId == request.auth.uid && incoming().ownerId == request.auth.uid;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }
  }
}
